{
    "manifest_version": 3,
    "name": "Auto typer",
    "version": "1.1",
    "description": "This extension allows you to automatically type text into input fields.",
    "action": {
        "default_popup": "popup.html",
        "default_title": "Auto typer",
        "default_icon": "typing.png"
    },
    "permissions": [
        "activeTab",
        "scripting"
    ]
}